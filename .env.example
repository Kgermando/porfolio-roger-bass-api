PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=rogerbass
DB_SSLMODE=disable
DB_TIMEZONE=Africa/Kinshasa

# JWT — change this to a long random secret in production!
JWT_SECRET=rogerbass_super_secret_jwt_key_change_me_in_production

ALLOW_ORIGINS=http://localhost:4200

# ── Backblaze B2 (image uploads) ─────────────────────────────────────────────
# Create a bucket + application key at https://www.backblaze.com/b2/buckets.html
BACKBLAZE_KEY_ID=your_key_id
BACKBLAZE_APPLICATION_KEY=your_application_key
BACKBLAZE_BUCKET_ID=your_bucket_id
BACKBLAZE_BUCKET_NAME=your_bucket_name

# ── SMTP (contact form email notifications) ───────────────────────────────────
# Example for Gmail: host=smtp.gmail.com, port=587
# Use an App Password if 2FA is enabled on your Google account.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
# Admin address that receives contact form notifications
EMAIL_ADMIN_TO=admin@rogerbass.com
